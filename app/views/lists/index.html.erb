<div class="lists">
  <h3>Lists</h3>
  <% if @lists.present? %>

      <table class="table table-sm table-hover">
        <thead>
          <tr>
            <th>Name</th>
            <th>Shared with</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @lists.each do |list| %>
            <tr>
              <td><%= list.name %></td>
              <td><%= list.permissions.map { |perm| perm.user.name unless perm.user == current_user }.compact.join(', ') %></td>
              <td>
                <%= link_to 'Items', list_items_path(list.id) %> |
                <%= link_to 'Edit', edit_list_path(list.id) %> |
                <%= link_to 'Delete', list_path(list), data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete this list?' } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
  <% else %>
    <h4 class="text-muted">
      No lists to manage yet. Click New below to add one.
    </h4>
  <% end %>
  <div class="mb-3 form-buttons">
    <%= link_to 'New', { action: :new }, { class: 'btn btn-secondary' } %>
  </div>
</div>
