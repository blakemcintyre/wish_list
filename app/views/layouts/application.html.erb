<!DOCTYPE html>
<html>
<head>
  <title>WishList</title>
  <%= stylesheet_link_tag 'application', media: 'all' %>
  <%= javascript_importmap_tags %>
  <%= csrf_meta_tags %>
</head>
<body>
  <!-- Top Header -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light">
  <a class="navbar-brand" href="/">Wish List</a>
  <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
  </button>
  <div class="collapse navbar-collapse" id="navbarNav">
    <% if current_user %>
      <ul class="navbar-nav ms-auto">
        <% if current_user.admin? %>
          <li class="nav-item <%= active_nav_path_css_class(users_path) %>">
            <%= link_to('Users', users_path, { class: 'nav-link' }) %>
          </li>
        <% end %>
        <li class="nav-item <%= active_nav_path_css_class(edit_user_path(current_user)) %>">
          <%= link_to('Profile', edit_user_path(current_user), { class: 'nav-link' }) %>
        </li>
        <li class="nav-item">
          <%= link_to('Sign out', destroy_user_session_path, data: { turbo_method: :delete }, class: 'nav-link') %>
        </li>
      </ul>
    <% end %>
  </div>
</nav>
<!-- --------------------------------------------------------------------->
  <div class="container-fluid">
    <div class="row">
      <div id="side-user-list" class="col-1 col-md-1"><%= render 'shared/list_links' if current_user %></div>
      <div class="col-11 col-md-11 flash-message">
        <% if notice.present? %>
          <p class="lead bg-success"><%= notice %></p>
        <% end %>
        <% if alert.present? %>
          <p class="lead bg-danger"><%= alert %></p>
        <% end %>
        <%= yield %>
      </div>
    </div>
  </div>
</body>
</html>
